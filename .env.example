# ─── Database ───
# SQLite by default. For Postgres: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./hiresense.db

# ─── LLM keys ───
# Groq is the primary LLM (fast). Get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Gemini is the fallback LLM. https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── GitHub API (optional) ───
# Personal access token — raises rate limit 60 → 5000 req/hour.
GITHUB_TOKEN=your_github_pat_here

# ─── Server / CORS ───
# Comma-separated allowed origins for the frontend, or "*" for any (demo).
# Production example: https://your-app.vercel.app
CORS_ORIGINS=*
PORT=8000

# ─── App ───
APP_VERSION=1.0.0
MAX_FILE_SIZE_MB=10
